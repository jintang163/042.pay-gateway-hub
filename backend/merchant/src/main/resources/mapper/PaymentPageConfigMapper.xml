<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.payhub.merchant.mapper.PaymentPageConfigMapper">

    <resultMap id="PaymentPageConfigMap" type="com.payhub.merchant.entity.PaymentPageConfig">
        <id column="id" property="id"/>
        <result column="merchant_no" property="merchantNo"/>
        <result column="page_title" property="pageTitle"/>
        <result column="logo_url" property="logoUrl"/>
        <result column="primary_color" property="primaryColor"/>
        <result column="secondary_color" property="secondaryColor"/>
        <result column="background_color" property="backgroundColor"/>
        <result column="text_color" property="textColor"/>
        <result column="button_color" property="buttonColor"/>
        <result column="button_text_color" property="buttonTextColor"/>
        <result column="template_code" property="templateCode"/>
        <result column="custom_css" property="customCss"/>
        <result column="footer_text" property="footerText"/>
        <result column="return_url" property="returnUrl"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <select id="selectPageList" parameterType="map" resultMap="PaymentPageConfigMap">
        SELECT
            id,
            merchant_no,
            page_title,
            logo_url,
            primary_color,
            secondary_color,
            background_color,
            text_color,
            button_color,
            button_text_color,
            color_scheme_code,
            custom_css,
            footer_text,
            return_url,
            status,
            created_at,
            updated_at,
            deleted
        FROM payment_page_config
        <where>
            deleted = 0
            <if test="params.merchantNo != null and params.merchantNo != ''">
                AND merchant_no = #{params.merchantNo}
            </if>
            <if test="params.merchantName != null and params.merchantName != ''">
                AND merchant_no IN (
                    SELECT merchant_no FROM merchant_info WHERE merchant_name LIKE CONCAT('%', #{params.merchantName}, '%')
                )
            </if>
            <if test="params.colorSchemeCode != null and params.colorSchemeCode != ''">
                AND color_scheme_code = #{params.colorSchemeCode}
            </if>
            <if test="params.status != null">
                AND status = #{params.status}
            </if>
        </where>
        ORDER BY created_at DESC
    </select>

</mapper>
